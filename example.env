# Phantix Command Centre — Environment Variables
# Copy this to .env and fill in your values. Never commit .env.

PORT=3000
NODE_ENV=development

# Firebase Admin (server-side)
# LOCAL: place firebase-service-account.json at project root
# VERCEL: paste full JSON as single-line string in Vercel env vars
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID"}

# Firebase Client SDK (sent to browser via /api/config/firebase)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123:web:abc

# Admin registration key (change before sharing the URL)
ADMIN_REGISTRATION_KEY=PHANTIX-ADMIN-2026
