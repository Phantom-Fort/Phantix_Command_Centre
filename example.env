# Phantix Command Centre — Environment Variables
# Copy this to .env and fill in your values. Never commit .env.
 
PORT=3000
NODE_ENV=development
 
# CORS — comma-separated list of allowed origins (your Vercel URL + any custom domain)
# Leave blank or omit for local dev (all origins allowed)
ALLOWED_ORIGINS=https://phantix-command-centre.vercel.app/
 
# Firebase Admin SDK (server-side only — never exposed to browser)
# LOCAL DEV: place firebase-service-account.json at project root (it is gitignored)
# VERCEL:    paste the full JSON as a single-line string in Vercel Environment Variables
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID"}
 
# Firebase Client SDK — sent to browser via GET /api/config/firebase
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123:web:abc
 
# Admin registration key — change this before sharing the URL
ADMIN_REGISTRATION_KEY=*******-*****-2026
